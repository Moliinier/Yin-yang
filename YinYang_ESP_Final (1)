--======================================================================
--  REVIVE AURA
--======================================================================

local AuraConnection = nil

local function enableReviveAura()
    ReviveAuraEnabled = true
    
    if AuraConnection then AuraConnection:Disconnect() end
    
    AuraConnection = RunService.Heartbeat:Connect(function()
        if not ReviveAuraEnabled then return end
        if not LocalPlayer.Character then return end
        local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                local theirRoot = player.Character:FindFirstChild("HumanoidRootPart")
                
                if humanoid and theirRoot then
                    local dist = (myRoot.Position - theirRoot.Position).Magnitude
                    if dist <= 15 then
                        -- Revivir si tiene poca vida o está caído
                        if humanoid.Health > 0 and humanoid.Health < humanoid.MaxHealth * 0.5 then
                            humanoid.Health = humanoid.MaxHealth
                        end
                    end
                end
            end
        end
    end)
end

local function disableReviveAura()
    ReviveAuraEnabled = false
    if AuraConnection then
        AuraConnection:Disconnect()
        AuraConnection = nil
    end
end

--======================================================================
--  AUTO CARRY
--======================================================================

local CarryConnection = nil

local function enableAutoCarry()
    AutoCarryEnabled = true
    
    if CarryConnection then CarryConnection:Disconnect() end
    
    CarryConnection = RunService.Heartbeat:Connect(function()
        if not AutoCarryEnabled then return end
        if not LocalPlayer.Character then return end
        local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local myHumanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not myHumanoid or myHumanoid.Health <= 0 then return end
        
        local closestDowned = nil
        local closestDist = math.huge
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                local theirRoot = player.Character:FindFirstChild("HumanoidRootPart")
                
                if humanoid and theirRoot and humanoid.Health > 0 then
                    local dist = (myRoot.Position - theirRoot.Position).Magnitude
                    
                    -- Detectar si está caído/downed
                    local isDowned = false
                    
                    -- Método 1: Health muy baja
                    if humanoid.Health <= humanoid.MaxHealth * 0.1 then
                        isDowned = true
                    end
                    
                    -- Método 2: Estado Ragdoll/FallingDown
                    local state = humanoid:GetState()
                    if state == Enum.HumanoidStateType.Ragdoll or 
                       state == Enum.HumanoidStateType.Physics or 
                       state == Enum.HumanoidStateType.FallingDown or
                       state == Enum.HumanoidStateType.Seated then
                        isDowned = true
                    end
                    
                    -- Método 3: Buscar indicador en el personaje (común en Evade)
                    if player.Character:FindFirstChild("Downed") or 
                       player.Character:FindFirstChild("Stunned") or
                       player.Character:FindFirstChild("IsDowned") or
                       player.Character:FindFirstChild("Carrying") then
                        isDowned = true
                    end
                    
                    if isDowned and dist < closestDist then
                        closestDist = dist
                        closestDowned = theirRoot
                    end
                end
            end
        end
        
        if closestDowned and closestDist <= 30 then
            -- Moverse hacia el jugador caído
            myHumanoid:MoveTo(closestDowned.Position)
        end
    end)
end

local function disableAutoCarry()
    AutoCarryEnabled = false
    if CarryConnection then
        CarryConnection:Disconnect()
        CarryConnection = nil
    end
end

--======================================================================
--  AUTO SPAWN (Auto Respawn)
--======================================================================

local SpawnConnection = nil

local function enableAutoSpawn()
    AutoSpawnEnabled = true
    
    if SpawnConnection then SpawnConnection:Disconnect() end
    
    SpawnConnection = RunService.Heartbeat:Connect(function()
        if not AutoSpawnEnabled then return end
        
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        
        if humanoid and humanoid.Health <= 0 then
            -- Forzar respawn inmediato
            task.wait(0.5)
            LocalPlayer:LoadCharacter()
        end
    end)
end

local function disableAutoSpawn()
    AutoSpawnEnabled = false
    if SpawnConnection then
        SpawnConnection:Disconnect()
        SpawnConnection = nil
    end
end

